<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/family#"
     xml:base="http://example.org/family"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#">

    <owl:Ontology rdf:about="http://example.org/family"/>

    <!-- Classes -->
    <owl:Class rdf:about="http://example.org/family#Person"/>
    <owl:Class rdf:about="http://example.org/family#OldPerson">
        <rdfs:subClassOf rdf:resource="http://example.org/family#Person"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/family#Man">
        <rdfs:subClassOf rdf:resource="http://example.org/family#Person"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/family#Woman">
        <rdfs:subClassOf rdf:resource="http://example.org/family#Person"/>
    </owl:Class>

    <!-- Data Properties -->
    <owl:DatatypeProperty rdf:about="http://example.org/family#hasAge">
        <rdfs:domain rdf:resource="http://example.org/family#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/family#hasName">
        <rdfs:domain rdf:resource="http://example.org/family#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- Object Properties -->
    <owl:ObjectProperty rdf:about="http://example.org/family#hasParent">
        <rdfs:domain rdf:resource="http://example.org/family#Person"/>
        <rdfs:range rdf:resource="http://example.org/family#Person"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/family#hasChild">
        <owl:inverseOf rdf:resource="http://example.org/family#hasParent"/>
        <rdfs:domain rdf:resource="http://example.org/family#Person"/>
        <rdfs:range rdf:resource="http://example.org/family#Person"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/family#hasSibling">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://example.org/family#Person"/>
        <rdfs:range rdf:resource="http://example.org/family#Person"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/family#hasBrother">
        <rdfs:subPropertyOf rdf:resource="http://example.org/family#hasSibling"/>
        <rdfs:domain rdf:resource="http://example.org/family#Person"/>
        <rdfs:range rdf:resource="http://example.org/family#Man"/>
    </owl:ObjectProperty>

    <!-- Individuals -->
    <owl:NamedIndividual rdf:about="http://example.org/family#Alice">
        <rdf:type rdf:resource="http://example.org/family#Woman"/>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">72</hasAge>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alice</hasName>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/family#Bob">
        <rdf:type rdf:resource="http://example.org/family#Man"/>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">45</hasAge>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bob</hasName>
        <hasParent rdf:resource="http://example.org/family#Alice"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/family#Charlie">
        <rdf:type rdf:resource="http://example.org/family#Man"/>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">65</hasAge>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Charlie</hasName>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/family#Diana">
        <rdf:type rdf:resource="http://example.org/family#Woman"/>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">38</hasAge>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diana</hasName>
        <hasParent rdf:resource="http://example.org/family#Alice"/>
        <hasSibling rdf:resource="http://example.org/family#Bob"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/family#Eve">
        <rdf:type rdf:resource="http://example.org/family#Woman"/>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">70</hasAge>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eve</hasName>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/family#Frank">
        <rdf:type rdf:resource="http://example.org/family#Man"/>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">15</hasAge>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Frank</hasName>
        <hasParent rdf:resource="http://example.org/family#Bob"/>
    </owl:NamedIndividual>

</rdf:RDF>
